{
  "name": "energy-dislocation-engine-preview",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-04-16",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true
    },
    "traces": {
      "enabled": true
    }
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "energy_dislocation",
      "database_id": "9db64b68-6ffc-4be2-a2c6-667691a5801f"
    }
  ],
  "vars": {
    "APP_ENV": "local",
    "PRODUCTION_ORIGIN": "",
    "ENABLE_MACRO_SIGNALS": "false",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otlp-gateway-prod-gb-south-1.grafana.net/otlp"
  },
  "env": {
    "preview": {
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "energy_dislocation",
          "database_id": "f9e3848e-20e6-43f0-8b0f-4fb652572d16"
        }
      ],
      "vars": {
        "APP_ENV": "preview",
        "PRODUCTION_ORIGIN": "",
        "ENABLE_MACRO_SIGNALS": "false",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otlp-gateway-prod-gb-south-1.grafana.net/otlp"
      }
    },
    "production": {
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "energy_dislocation",
          "database_id": "9db64b68-6ffc-4be2-a2c6-667691a5801f"
        }
      ],
      "vars": {
        "APP_ENV": "production",
        "PRODUCTION_ORIGIN": "https://oil-shock-web.vercel.app",
        "ENABLE_MACRO_SIGNALS": "false",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otlp-gateway-prod-gb-south-1.grafana.net/otlp"
      }
    }
  }
}
