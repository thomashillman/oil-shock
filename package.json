{
  "name": "oil-shock",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "workerd"]
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  },
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "lint": "corepack pnpm -r --if-present lint",
    "test": "corepack pnpm -r --if-present test",
    "dev:worker": "corepack pnpm --filter @oil-shock/worker dev",
    "dev:web": "corepack pnpm --filter @oil-shock/app dev",
    "db:migrate:local": "tsx scripts/apply-all-migrations.ts --local",
    "poc:run": "corepack pnpm db:migrate:local && corepack pnpm build",
    "replay:validate": "tsx scripts/replay-validate.ts",
    "docs:check": "node scripts/docs-check.mjs",
    "ci:preflight": "corepack pnpm lint && corepack pnpm -r --if-present typecheck && corepack pnpm test && corepack pnpm build",
    "phase6a:evidence": "tsx scripts/phase6a/capture-canary-evidence.ts"
  }
}
